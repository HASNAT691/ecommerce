<div class="container my-5 text-center">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="bg-white p-5 rounded shadow-sm border mt-5">
        <div class="mb-4">
          <i class="fas fa-exclamation-circle fa-4x text-muted"></i>
        </div>
        <h1 class="display-6 fw-bold mb-3" style="font-family: 'Outfit', sans-serif; color: #111;">
          <%= locals.title || "Something Went Wrong" %>
        </h1>
        <p class="text-secondary mb-4 fs-5">
          <%= locals.message || "An unexpected error occurred while processing your request. Please try again later." %>
        </p>
        <div class="d-flex justify-content-center gap-3">
          <a href="/" class="btn btn-dark px-4 py-2 text-uppercase tracking-wider fs-6">
            <i class="fas fa-home me-2"></i>Go to Home
          </a>
          <a href="https://wa.me/923457139939" target="_blank" class="btn btn-outline-dark px-4 py-2 text-uppercase tracking-wider fs-6">
            <i class="fab fa-whatsapp me-2"></i>Contact Support
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
