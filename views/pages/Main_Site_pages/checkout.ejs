<style>
  body {
    font-family: "Inter", sans-serif;
    background-color: #f8f9fa;
  }

  .checkout-card {
    border-radius: 1rem;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.05);
    background-color: #fff;
    /* Ensure white background for cards */
  }

  .total-box {
    background-color: #f0f0f0;
    /* Lighter background for totals */
    border-radius: 0.5rem;
    padding: 1rem;
  }

  #jazzcashDetails {
    display: none;
    /* Hidden by default */
    background-color: #e9ecef;
    /* Slightly darker than total-box */
    padding: 1rem;
    border-radius: 0.5rem;
    margin-top: 1rem;
    border: 1px solid #dee2e6;
  }

  .product-item-img {
    width: 50px;
    height: 60px;
    object-fit: cover;
    border-radius: 0.3rem;
  }

  .accordion-button {
    font-weight: 600;
    color: #212529;
    /* Darker text for accordion headers */
    background-color: #f8f9fa;
    /* Light background */
    border-bottom: 1px solid rgba(0, 0, 0, 0.125);
  }

  .accordion-button:not(.collapsed) {
    color: #007bff;
    /* Primary blue when active */
    background-color: #e7f1ff;
    /* Light blue background when active */
    box-shadow: inset 0 -1px 0 rgba(0, 0, 0, 0.125);
  }

  .accordion-item {
    border-radius: 0.5rem;
    margin-bottom: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.125);
  }

  .btn-success {
    background-color: #28a745;
    border-color: #28a745;
  }

  .btn-success:hover {
    background-color: #218838;
    border-color: #1e7e34;
  }

  .form-control,
  .btn {
    border-radius: 0.3rem;
  }

  /* Order Confirmed Modal Animation */
  .modal-body .fa-check-circle {
    animation: bounceIn 0.8s forwards;
  }

  @keyframes bounceIn {

    0%,
    20%,
    40%,
    60%,
    80%,
    100% {
      transition-timing-function: cubic-bezier(0.215, 0.61, 0.355, 1);
    }

    0% {
      opacity: 0;
      transform: scale3d(0.3, 0.3, 0.3);
    }

    20% {
      transform: scale3d(1.1, 1.1, 1.1);
    }

    40% {
      transform: scale3d(0.9, 0.9, 0.9);
    }

    60% {
      opacity: 1;
      transform: scale3d(1.03, 1.03, 1.03);
    }

    80% {
      transform: scale3d(0.97, 0.97, 0.97);
    }

    100% {
      opacity: 1;
      transform: scale3d(1, 1, 1);
    }
  }
</style>

<body class="bg-light">
  <div class="container my-5">
    <h2 class="text-center mb-4">Checkout</h2>

    <% if (!cart || cart.items.length===0) { %>
      <div class="text-center py-5">
        <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
        <h3 class="mt-3">Your cart is empty!</h3>
        <p>Please add some items to your cart before proceeding to checkout.</p>
        <a href="/" class="btn btn-primary mt-3">Continue Shopping</a>
      </div>
      <% } else { %>
        <div class="row g-4">
          <!-- Forms Section -->
          <div class="col-md-7">
            <div class="accordion" id="checkoutAccordion">
              <!-- Shipping Information -->
              <div class="accordion-item checkout-card">
                <h2 class="accordion-header" id="headingOne">
                  <button class="accordion-button" type="button" data-bs-toggle="collapse"
                    data-bs-target="#collapseOne">
                    1. Shipping Information
                  </button>
                </h2>
                <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#checkoutAccordion">
                  <div class="accordion-body">
                    <form id="shippingForm">
                      <div class="mb-3">
                        <label for="name" class="form-label">Full Name</label>
                        <input type="text" class="form-control" id="name" name="name"
                          value="<%= user ? user.name : '' %>" required />
                      </div>
                      <div class="mb-3">
                        <label for="email" class="form-label">Email Address</label>
                        <input type="email" class="form-control" id="email" name="email"
                          value="<%= user ? user.email : '' %>" required readonly />
                      </div>
                      <div class="mb-3">
                        <label for="addressLine1" class="form-label">Address Line 1</label>
                        <input type="text" class="form-control" id="addressLine1" name="addressLine1"
                          value="<%= defaultAddress ? defaultAddress.addressLine1 : '' %>" required />
                      </div>
                      <div class="mb-3">
                        <label for="addressLine2" class="form-label">Address Line 2 (Optional)</label>
                        <input type="text" class="form-control" id="addressLine2" name="addressLine2"
                          value="<%= defaultAddress ? defaultAddress.addressLine2 : '' %>" />
                      </div>
                      <div class="row">
                        <div class="col-md-6 mb-3">
                          <label for="city" class="form-label">City</label>
                          <input type="text" class="form-control" id="city" name="city"
                            value="<%= defaultAddress ? defaultAddress.city : '' %>" required />
                        </div>
                        <div class="col-md-6 mb-3">
                          <label for="state" class="form-label">State/Province</label>
                          <input type="text" class="form-control" id="state" name="state"
                            value="<%= defaultAddress ? defaultAddress.state : 'Punjab' %>" required />
                        </div>
                      </div>
                      <div class="row">
                        <div class="col-md-6 mb-3">
                          <label for="zipCode" class="form-label">ZIP Code</label>
                          <input type="text" class="form-control" id="zipCode" name="zipCode"
                            value="<%= defaultAddress ? defaultAddress.zipCode : '' %>" required />
                        </div>
                        <div class="col-md-6 mb-3">
                          <label for="country" class="form-label">Country</label>
                          <input type="text" class="form-control" id="country" name="country"
                            value="<%= defaultAddress ? defaultAddress.country : 'Pakistan' %>" readonly />
                        </div>
                      </div>
                      <div class="mb-3">
                        <label for="phone" class="form-label">Phone Number</label>
                        <input type="tel" class="form-control" id="phone" name="phone"
                          value="<%= defaultAddress ? defaultAddress.phone : (user ? user.phone : '') %>" required />
                      </div>
                    </form>
                  </div>
                </div>
              </div>

              <!-- Delivery Method -->
              <div class="accordion-item checkout-card">
                <h2 class="accordion-header" id="headingTwo">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                    data-bs-target="#collapseTwo">
                    2. Delivery Method
                  </button>
                </h2>
                <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#checkoutAccordion">
                  <div class="accordion-body">
                    <form id="deliveryForm">
                      <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="delivery" id="deliveryStandard"
                          value="Standard" required checked />
                        <label class="form-check-label" for="deliveryStandard">Standard (PKR 200, 3-5 days)</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="delivery" id="deliveryExpress"
                          value="Express" required />
                        <label class="form-check-label" for="deliveryExpress">Express (PKR 500, 1-2 days)</label>
                      </div>
                    </form>
                  </div>
                </div>
              </div>

              <!-- Payment Method -->
              <div class="accordion-item checkout-card">
                <h2 class="accordion-header" id="headingThree">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                    data-bs-target="#collapseThree">
                    3. Payment Method
                  </button>
                </h2>
                <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#checkoutAccordion">
                  <div class="accordion-body">
                    <form id="paymentForm">
                      <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="payment" id="paymentCOD" value="COD" required
                          checked />
                        <label class="form-check-label" for="paymentCOD">Cash on Delivery</label>
                      </div>
                      <div class="form-check">
                        <input id="easypaisaRadio" class="form-check-input" type="radio" name="payment" value="EasyPaisa"
                          required />
                        <label class="form-check-label" for="easypaisaRadio">EasyPaisa</label>
                      </div>

                      <!-- EasyPaisa Details Section -->
                      <div id="easypaisaDetails" style="display: none;">
                        <h6 class="mb-2">EasyPaisa Payment Info</h6>
                        <ul class="list-unstyled mb-3">
                          <li><strong>Account Title:</strong> HASNAT KHALID</li>
                          <li><strong>Account No:</strong> 03457139939</li>
                          <li><strong>Bank:</strong> EasyPaisa Mobile Account</li>
                        </ul>
                        <div class="mb-3">
                          <label for="screenshot" class="form-label">Upload Payment Screenshot</label>
                          <input type="file" class="form-control" id="screenshot" name="screenshot" accept="image/*"
                            required />
                        </div>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Order Summary -->
          <div class="col-md-5">
            <div class="card p-4 checkout-card">
              <h5 class="mb-3">Order Summary</h5>
              <ul class="list-group mb-3">
                <% cart.items.forEach(item=> { %>
                  <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                      <img src="<%= item.picture[0].startsWith('http') ? item.picture[0] : '/uploads/' + item.picture[0] %>"
                        onerror="this.onerror=null;this.src='https://placehold.co/50x60/f0f0f0/333333?text=No+Img';"
                        alt="<%= item.title %>" class="product-item-img me-2" />
                      <%= item.title %> (x<%= item.quantity %>)
                    </div>
                    <span>PKR <%= (item.price * item.quantity).toFixed(2) %></span>
                  </li>
                  <% }); %>

                    <li class="list-group-item d-flex justify-content-between">
                      Subtotal
                      <span>PKR <%= cart.total.toFixed(2) %></span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                      Shipping (<span id="deliveryMethodSummary">Standard</span>)
                      <span id="shippingFeeSummary">PKR 200</span>
                    </li>
                    <li class="list-group-item total-box d-flex justify-content-between">
                      <strong>Total</strong>
                      <strong id="totalSummary">PKR <%= (cart.total + 200).toFixed(2) %></strong>
                    </li>
              </ul>
              <button id="placeOrderBtn" class="btn btn-success w-100 mt-3" disabled>
                Place Order
              </button>
            </div>
          </div>
        </div>
        <% } %>
  </div>

  <!-- Order Confirmed Animation Modal -->
  <div class="modal fade" id="orderConfirmedModal" tabindex="-1" aria-labelledby="orderConfirmedModalLabel"
    aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content text-center p-4">
        <div class="modal-body">
          <i class="fas fa-check-circle fa-5x text-success mb-3 animate__animated animate__bounceIn"></i>
          <h4>Order Placed Successfully!</h4>
          <p>Thank you for your purchase. Your order has been confirmed.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Custom Alert Message Container -->
  <div class="alert-message-container">
    <div id="customAlert" class="alert-message"></div>
  </div>

  <!-- Bootstrap JS (bundle includes Popper) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    xintegrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
    crossorigin="anonymous"></script>
  <script>
    // Custom Alert Function
    function showAlert(message, type = "success") {
      const alertBox = document.getElementById("customAlert");
      alertBox.textContent = message;
      alertBox.classList.remove(
        "bg-success",
        "bg-danger",
        "bg-info",
        "bg-warning",
        "text-dark"
      );
      if (type === "success") {
        alertBox.classList.add("bg-success");
      } else if (type === "error") {
        alertBox.classList.add("bg-danger");
      } else if (type === "info") {
        alertBox.classList.add("bg-info");
      } else if (type === "warning") {
        alertBox.classList.add("bg-warning", "text-dark");
      }
      alertBox.classList.add("show");
      setTimeout(() => {
        alertBox.classList.remove("show");
      }, 3000);
    }

    const placeOrderBtn = document.getElementById("placeOrderBtn");
    const shippingForm = document.getElementById("shippingForm");
    const deliveryForm = document.getElementById("deliveryForm");
    const paymentForm = document.getElementById("paymentForm");
    const easypaisaRadio = document.getElementById("easypaisaRadio");
    const easypaisaDetails = document.getElementById("easypaisaDetails");
    const screenshotInput = document.getElementById("screenshot");

    const deliveryMethodSummary = document.getElementById(
      "deliveryMethodSummary"
    );
    const shippingFeeSummary = document.getElementById("shippingFeeSummary");
    const totalSummary = document.getElementById("totalSummary");

    let currentShippingFee = 200; // Default to Standard shipping (PKR 200)

    // EJS variable for cart subtotal - this will be replaced by server-side data
    const cartSubtotal = parseFloat("<%= cart.total %>");

    // Show/hide EasyPaisa section and update shipping/total
    document.querySelectorAll('input[name="payment"]').forEach((el) => {
      el.addEventListener("change", () => {
        if (easypaisaRadio.checked) {
          easypaisaDetails.style.display = "block";
        } else {
          easypaisaDetails.style.display = "none";
        }
        validateForms();
      });
    });

    // Update shipping fee and total based on delivery method
    document.querySelectorAll('input[name="delivery"]').forEach((el) => {
      el.addEventListener("change", () => {
        if (el.value === "Standard") {
          currentShippingFee = 200;
          deliveryMethodSummary.textContent = "Standard";
        } else if (el.value === "Express") {
          currentShippingFee = 500;
          deliveryMethodSummary.textContent = "Express";
        }
        shippingFeeSummary.textContent = `PKR ${currentShippingFee}`;
        updateOrderTotal();
        validateForms();
      });
    });

    const updateOrderTotal = () => {
      const newTotal = cartSubtotal + currentShippingFee;
      totalSummary.textContent = `PKR ${newTotal.toFixed(2)}`;
    };

    // Validate forms
    const validateForms = () => {
      // Check HTML5 validity for each form
      const isShippingValid = shippingForm.checkValidity();
      const isDeliverySelected = deliveryForm.checkValidity();
      const isPaymentSelected = paymentForm.checkValidity();

      let isEasyPaisaValid = true;
      if (easypaisaRadio.checked) {
        isEasyPaisaValid = screenshotInput.files.length > 0; // Check if file is selected for EasyPaisa
      }

      // Enable/disable Place Order button
      placeOrderBtn.disabled = !(
        isShippingValid &&
        isDeliverySelected &&
        isPaymentSelected &&
        isEasyPaisaValid
      );
    };

    // Re-validate on any input/change in relevant forms
    document
      .querySelectorAll(
        "#shippingForm input, #shippingForm textarea, #deliveryForm input, #paymentForm input, #screenshot"
      )
      .forEach((input) => {
        input.addEventListener("input", validateForms);
        input.addEventListener("change", validateForms); // 'change' is important for radios/files
      });

    // Handle form submission
    placeOrderBtn.addEventListener("click", async (event) => {
      event.preventDefault(); // Prevent default form submission

      if (placeOrderBtn.disabled) {
        showAlert("Please fill out all required fields.", "error");
        return;
      }

      const formData = new FormData();

      // Append shipping info
      formData.append("name", document.getElementById("name").value);
      formData.append("email", document.getElementById("email").value);
      formData.append(
        "addressLine1",
        document.getElementById("addressLine1").value
      );
      formData.append(
        "addressLine2",
        document.getElementById("addressLine2").value
      );
      formData.append("city", document.getElementById("city").value);
      formData.append("state", document.getElementById("state").value);
      formData.append("zipCode", document.getElementById("zipCode").value);
      formData.append("country", document.getElementById("country").value);
      formData.append("phone", document.getElementById("phone").value);

      // Append delivery method
      formData.append(
        "deliveryMethod",
        document.querySelector('input[name="delivery"]:checked').value
      );

      // Append payment method
      const paymentMethod = document.querySelector(
        'input[name="payment"]:checked'
      ).value;
      formData.append("paymentMethod", paymentMethod);

      // Append screenshot if EasyPaisa is selected
      if (paymentMethod === "EasyPaisa" && screenshotInput.files.length > 0) {
        formData.append("screenshot", screenshotInput.files[0]);
      }

      try {
        const response = await fetch("/checkout", {
          method: "POST",
          body: formData, // FormData handles Content-Type automatically for file uploads
        });

        const data = await response.json(); // Assuming JSON response from backend

        if (response.ok) {
          const orderConfirmedModal = new bootstrap.Modal(
            document.getElementById("orderConfirmedModal")
          );
          orderConfirmedModal.show();

          setTimeout(() => {
            window.location.href = "/secondpage";
          }, 3000);
        } else {
          showAlert(
            data.error || "Failed to place order. Please try again.",
            "error"
          );
        }
      } catch (error) {
        console.error("Error placing order:", error);
        showAlert(
          "An unexpected error occurred while placing your order.",
          "error"
        );
      }
    });

    // Initial validation and total calculation on page load
    document.addEventListener("DOMContentLoaded", () => {
      // Set initial checked state based on HTML (Standard delivery, COD payment)
      document.getElementById("deliveryStandard").checked = true;
      document.getElementById("paymentCOD").checked = true;

      validateForms();
      updateOrderTotal(); // Call to set initial total with default shipping
    });
  </script>
</body>