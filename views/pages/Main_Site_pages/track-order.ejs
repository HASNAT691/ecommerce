<style>
    .track-card {
        background-color: #fff;
        padding: 2.5rem;
        border-radius: 1rem;
        box-shadow: 0 0 25px rgba(0, 0, 0, 0.1);
        max-width: 600px;
        width: 95%;
        text-align: center;
        /* Add some top margin to ensure it doesn't stick to the top if layout.ejs doesn't provide it */
        margin-top: 50px;
        margin-bottom: 50px;
    }

    .order-status-section {
        display: none;
        /* Hidden by default */
        margin-top: 2rem;
        text-align: left;
        border-top: 1px dashed #e0e0e0;
        padding-top: 1.5rem;
    }

    .order-status-badge {
        padding: .5em .75em;
        border-radius: .5rem;
        font-size: 1em;
        font-weight: 700;
    }

    .status-Pending {
        background-color: #ffc107;
        color: #343a40;
    }

    /* Warning yellow */
    .status-Confirmed {
        background-color: #0d6efd;
        color: #fff;
    }

    /* Primary blue */
    .status-Shipped {
        background-color: #17a2b8;
        color: #fff;
    }

    /* Info cyan */
    .status-Delivered {
        background-color: #28a745;
        color: #fff;
    }

    /* Success green */
    .status-Cancelled {
        background-color: #dc3545;
        color: #fff;
    }

    /* Danger red */
    .product-item-img {
        width: 40px;
        height: 40px;
        object-fit: cover;
        border-radius: 0.25rem;
    }

    .order-item-list .list-group-item {
        font-size: 0.9em;
    }
</style>

    <!-- Track order card -->
    <div class="container d-flex justify-content-center align-items-center">
        <div class="track-card">
            <h2 class="mb-4">Track Your Order</h2>
            <p class="text-muted mb-4">Enter your Order ID to check the status of your purchase.</p>

            <form id="trackOrderForm" class="needs-validation" novalidate>
                <div class="input-group mb-3">
                    <input type="text" class="form-control form-control-lg" id="orderIdInput"
                        placeholder="Enter Order ID" required>
                    <button class="btn btn-primary btn-lg" type="submit">Track Order</button>
                    <div class="invalid-feedback">
                        Please enter an Order ID.
                    </div>
                </div>
            </form>

            <div id="orderStatusDisplay" class="order-status-section">
                <h4 class="mb-3">Order Status for #<span id="displayOrderId"></span></h4>
                <p class="mb-2">Current Status: <span id="currentStatus" class="order-status-badge"></span></p>
                <p class="mb-2">Order Date: <span id="orderDate"></span></p>
                <p class="mb-2">Total Amount: <span id="orderTotal"></span></p>

                <h5 class="mt-4 mb-2">Shipping Address:</h5>
                <div id="shippingAddressDisplay">
                    <!-- Address details will be injected here -->
                </div>

                <h5 class="mt-4 mb-2">Items:</h5>
                <ul id="orderItemsList" class="list-group list-group-flush order-item-list">
                    <!-- Order items will be injected here -->
                </ul>
            </div>

            <div id="noOrderFound" class="alert alert-warning mt-4" style="display: none;">
                <i class="fas fa-exclamation-triangle me-2"></i> No order found with that ID. Please check the ID and
                try again.
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const trackOrderForm = document.getElementById('trackOrderForm');
            const orderIdInput = document.getElementById('orderIdInput');
            const orderStatusDisplay = document.getElementById('orderStatusDisplay');
            const noOrderFound = document.getElementById('noOrderFound');

            trackOrderForm.addEventListener('submit', async (event) => {
                event.preventDefault();
                event.stopPropagation(); // Prevent default Bootstrap validation behavior

                if (!trackOrderForm.checkValidity()) {
                    trackOrderForm.classList.add('was-validated');
                    return;
                }

                trackOrderForm.classList.remove('was-validated'); // Remove validation state

                const orderId = orderIdInput.value.trim();
                noOrderFound.style.display = 'none'; // Hide previous error
                orderStatusDisplay.style.display = 'none'; // Hide previous results

                try {
                    const response = await fetch('/api/track-order', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ readableOrderId: orderId })
                    });
                    const data = await response.json();

                    if (response.ok && data.order) {
                        const order = data.order;
                        document.getElementById('displayOrderId').textContent = order.readableOrderId;

                        const statusBadge = document.getElementById('currentStatus');
                        statusBadge.className = `order-status-badge status-${order.status}`;
                        statusBadge.textContent = order.status;

                        document.getElementById('orderDate').textContent = new Date(order.orderDate).toLocaleDateString('en-PK', {
                            year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'
                        });
                        document.getElementById('orderTotal').textContent = `PKR ${order.total.toFixed(2)}`;

                        const shippingAddressDiv = document.getElementById('shippingAddressDisplay');
                        shippingAddressDiv.innerHTML = `
                                <p>${order.shippingAddress.name}</p>
                                <p>${order.shippingAddress.addressLine1}${order.shippingAddress.addressLine2 ? ', ' + order.shippingAddress.addressLine2 : ''}</p>
                                <p>${order.shippingAddress.city}, ${order.shippingAddress.state} ${order.shippingAddress.zipCode}</p>
                                <p>${order.shippingAddress.country}</p>
                                <p>Phone: ${order.shippingAddress.phone}</p>
                            `;

                        const orderItemsList = document.getElementById('orderItemsList');
                        orderItemsList.innerHTML = ''; // Clear previous items
                        order.items.forEach(item => {
                            const listItem = document.createElement('li');
                            listItem.className = 'list-group-item d-flex justify-content-between align-items-center';
                            // Ensure item.picture is a string for direct use in src
                            // Corrected image path: /uploads/ prefix added
                            const imgSrc = Array.isArray(item.picture) ? item.picture[0] : item.picture;
                            const imgPath = (imgSrc && imgSrc.startsWith('http')) ? imgSrc : `/uploads/${imgSrc}`;
                            listItem.innerHTML = `
                                    <div class="d-flex align-items-center">
                                        <img src="${imgPath}" onerror="this.onerror=null;this.src='https://placehold.co/40x40/f0f0f0/333333?text=No+Img';" alt="${item.title}" class="product-item-img me-2">
                                        ${item.title} (x${item.quantity})
                                    </div>
                                    <span>PKR ${(item.price * item.quantity).toFixed(2)}</span>
                                `;
                            orderItemsList.appendChild(listItem);
                        });

                        orderStatusDisplay.style.display = 'block'; // Show results
                    } else {
                        noOrderFound.style.display = 'block'; // Show "not found" message
                    }
                } catch (error) {
                    console.error('Error tracking order:', error);
                    noOrderFound.style.display = 'block'; // Show "not found" message on network error
                }
            });
        });
    </script>