
  <style>
    body {
      background: linear-gradient(135deg, #f6f8f9 0%, #e5ebee 100%);
      font-family: 'Inter', sans-serif;
    }

    .btn-gradient {
      background: linear-gradient(to right, #4A90E2, #6BDFFF);
      color: white;
      border: none;
    }

    .btn-gradient:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(74, 144, 226, 0.2);
    }

    .btn-gradient:active {
      transform: translateY(0);
      box-shadow: 0 4px 6px rgba(74, 144, 226, 0.15);
    }
    .form-control-underline {
        border: none;
        border-bottom: 2px solid #ccc;
        border-radius: 0;
        box-shadow: none;
        padding: 15 0 15 15;
    }

    .form-control-underline:focus {
        border-bottom-color: #4A90E2;
        box-shadow: none;
    }

    
  </style>


  <div class="container-fluid px-4 py-5">
    <div class="row justify-content-center">
      <div class="col-lg-12 col-md-10">
        <!-- Removed card & shadow -->
        <h2 class="mb-4 fw-semibold text-start">Create Category</h2>

        <form id="categoryForm" method="POST" action="#" novalidate class="needs-validation">
          <!-- Category Name -->
          <div class="mb-3">
            <label for="categoryName" class="form-label fw-bold">Category Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control form-control-underline" id="categoryName" name="categoryName" placeholder="e.g. Summer Collection" required>
            <div class="invalid-feedback">Category name is required.</div>
          </div>

          <!-- Subcategories -->
          <div id="subcategoryContainer">
            <label class="form-label fw-bold">Subcategories</label>
            <div class="input-group mb-2">
              <input type="text" class="form-control form-control-underline" name="subcategories[]" placeholder="e.g. Lawn / Cotton">
              <button class="btn btn-outline-secondary remove-subcategory d-none" type="button">Remove</button>
            </div>
          </div>

          <button type="button" id="addSubcategory" class="btn btn-sm btn-outline-primary mb-3">
            + Add Subcategory
          </button>

          <!-- Submit Button -->
          <button type="submit" class="btn btn-gradient w-100 py-2 rounded-3">
            Create Category
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS & Custom Script -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Bootstrap Validation
    (function () {
      'use strict';
      const form = document.getElementById('categoryForm');
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
        }
        form.classList.add('was-validated');
      });
    })();

    // Add/Remove Subcategories
    document.getElementById('addSubcategory').addEventListener('click', function () {
      const container = document.getElementById('subcategoryContainer');
      const inputGroup = document.createElement('div');
      inputGroup.className = 'input-group mb-2';

      inputGroup.innerHTML = `
        <input type="text" class="form-control" name="subcategories[]" placeholder="e.g. Laptops">
        <button class="btn btn-outline-danger remove-subcategory" type="button">Remove</button>
      `;
      container.appendChild(inputGroup);
    });

    document.getElementById('subcategoryContainer').addEventListener('click', function (e) {
      if (e.target.classList.contains('remove-subcategory')) {
        e.target.closest('.input-group').remove();
      }
    });
  </script>