<style>
    .table-wrapper {
        max-height: 70vh;
        overflow-y: auto;
    }

    .table thead th {
        position: sticky;
        top: 0;
        background: #0d6efd;
        color: #fff;
    }

    .desc-cell {
        max-width: 280px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .thumb-container img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 6px;
        transition: .25s;
    }

    .thumb-container {
        display: flex;
        gap: .3rem;
        flex-wrap: wrap;
    }

    .thumb-container img:hover {
        transform: scale(1.8);
        z-index: 10;
        box-shadow: 0 0 8px rgba(0, 0, 0, .4);
    }

    /* optional scrollbar style */
    .table-wrapper::-webkit-scrollbar {
        width: 6px;
    }

    .table-wrapper::-webkit-scrollbar-thumb {
        background: #c0c0c0;
        border-radius: 4px;
    }
</style>

<h3 class="mb-3 fw-semibold">Products</h3>

<!-- top row: search / create -->
<div class="row g-2 align-items-center mb-3">
    <div class="col-md-6">
        <form class="d-flex" method="GET" action="/admin/products">
            <input type="text" name="search" class="form-control me-2"
                placeholder="Search title / description / sub-category" value="<%= search || '' %>">
            <button class="btn btn-outline-primary"><i class="fas fa-search"></i></button>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a href="/admin/products/create" class="btn btn-info">
            <i class="fas fa-plus-circle me-1"></i>Create New
        </a>
    </div>
</div>

<!-- filters -->
<div class="row mb-3">
    <div class="col d-flex gap-3 flex-wrap justify-content-end">

        <!-- category filter -->
        <div class="dropdown">
            <button class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown">
                <%= currentCategory ? 'Category: ' +categories.find(c=>
                    c._id.toString()===currentCategory)?.categoryName : 'Filter by Category' %>
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/admin/products">All Categories</a></li>
                <% categories.forEach(c=>{ %>
                    <li><a class="dropdown-item" href="/admin/products?category=<%= c._id %>">
                            <%= c.categoryName %>
                        </a></li>
                    <% }) %>
            </ul>
        </div>

        <!-- sort -->
        <div class="dropdown">
            <button class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown">
                Sort: <%= currentSort==='desc' ?'High→Low':'Low→High' %>
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/admin/products?sort=asc">Low → High</a></li>
                <li><a class="dropdown-item" href="/admin/products?sort=desc">High → Low</a></li>
            </ul>
        </div>
    </div>
</div>

<!-- scrollable table -->
<div class="table-wrapper border rounded">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>Category</th>
                <th class="text-end">Price (PKR)</th>
                <th>Featured</th>
                <th>Images</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% products.forEach(p=>{ %>
                <tr>
                    <td class="small">
                        <%= p._id %>
                    </td>
                    <td><strong>
                            <%= p.title %>
                        </strong></td>
                    <td class="desc-cell" title="<%= p.description %>">
                        <%= p.description %>
                    </td>
                    <td>
                        <%= p.category ? p.category.categoryName : 'N/A' %>
                    </td>
                    <td class="text-end">
                        <%= p.price.toLocaleString() %>
                    </td>
                    <td class="text-center">
                        <%= p.isFeatured ? '★' : '' %>
                    </td>

                    <!-- images -->
                    <td>
                        <div class="thumb-container">
                            <% (p.images||[]).forEach(img=> { %>
                                <img src="<%= img.startsWith('http') ? img : '/uploads/' + img %>">
                                <% }) %>
                        </div>
                    </td>

                    <!-- actions -->
                    <td>
                        <a href="/admin/products/edit/<%= p._id %>" class="btn btn-sm btn-primary me-1">
                            <i class="fas fa-pen"></i>
                        </a>
                        <a href="/admin/products/delete/<%= p._id %>" class="btn btn-sm btn-danger"
                            onclick="return confirm('Delete this product?')">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
                <% }) %>
        </tbody>
    </table>
</div>

<!-- pagination (10 per page) -->
<nav class="mt-3">
    <ul class="pagination justify-content-center">
        <% if (page>1) { %>
            <li class="page-item"><a class="page-link" href="?page=<%= page-1 %>&<%= queryString %>">Prev</a></li>
            <% } %>

                <% for(let i=1;i<=totalPages;i++){ %>
                    <li class="page-item <%= page===i?'active':'' %>">
                        <a class="page-link" href="?page=<%= i %>&<%= queryString %>">
                            <%= i %>
                        </a>
                    </li>
                    <% } %>

                        <% if (page<totalPages) { %>
                            <li class="page-item"><a class="page-link"
                                    href="?page=<%= page+1 %>&<%= queryString %>">Next</a></li>
                            <% } %>
    </ul>
</nav>