<style>
  body {
    background: linear-gradient(135deg, #f6f8f9 0%, #e5ebee 100%);
  }

  .form-control-underline {
    border: none;
    border-bottom: 2px solid #ced4da;
    border-radius: 0;
  }

  .form-control-underline:focus {
    border-bottom-color: #4a90e2;
    box-shadow: none;
  }

  .btn-gradient {
    background: linear-gradient(to right, #4a90e2, #6bdfff);
    color: #fff;
    border: none;
  }

  .btn-gradient:hover {
    background: linear-gradient(to right, #357abd, #5ac8fa);
  }

  .drop-zone {
    border: 2px dashed #4a90e2;
    border-radius: 10px;
    padding: 40px;
    text-align: center;
    color: #6c757d;
    cursor: pointer;
    transition: 0.2s;
  }

  .drop-zone.dragover {
    background: #e9f7fc;
  }
</style>

<div class="container py-5">
  <h2 class="mb-4 fw-semibold">
    <i class="fas fa-box-open me-2"></i>Add New Product
  </h2>

  <form
    id="productForm"
    class="needs-validation"
    method="POST"
    enctype="multipart/form-data"
    novalidate
  >
    <!-- Title -->
    <div class="mb-3">
      <label class="form-label fw-bold">Product Title</label>
      <input
        type="text"
        name="title"
        class="form-control form-control-underline"
        required
        minlength="3"
        maxlength="100"
      />
    </div>

    <!-- Description -->
    <div class="mb-3">
      <label class="form-label fw-bold">Description (100–150 words)</label>
      <textarea
        name="description"
        id="desc"
        rows="5"
        class="form-control form-control-underline"
        required
      ></textarea>
      <div class="form-text" id="wordCount">0 words</div>
    </div>

    <!-- Price -->
    <div class="mb-3">
      <label class="form-label fw-bold">Price</label>
      <input
        type="number"
        name="price"
        step="0.01"
        min="0"
        class="form-control form-control-underline"
        required
      />
    </div>

    <div class="mb-3">
      <label for="inStock" class="form-label fw-bold">In Stock Quantity</label>
      <input
        type="number"
        class="form-control"
        id="inStock"
        name="inStock"
        placeholder="Enter quantity in stock"
        min="0"
        required
      />
      <div class="invalid-feedback">Please provide the stock quantity.</div>
    </div>

    <!-- Multiple images -->
    <div class="mb-3">
      <label class="form-label fw-bold">Images (JPG/JPEG/PNG/PDF)</label>
      <div id="dropZone" class="drop-zone">
        <i class="fas fa-cloud-upload-alt fa-2x mb-2"></i><br />Drag & drop or
        click
      </div>
      <!-- NOTE name = files  -->
      <input
        type="file"
        name="files"
        id="fileInp"
        multiple
        class="d-none"
        accept=".jpg,.jpeg,.png,.pdf"
      />
      <div id="fileName" class="form-text"></div>
    </div>

    <!-- Category -->
    <div class="mb-3">
      <label class="form-label fw-bold">Category</label>
      <select name="category" id="catSel" class="form-select" required>
        <option value="">Select category</option>
        <% categories.forEach(cat=> { %>
        <option
          value="<%= cat._id %>"
          data-subs="<%= cat.subcategories.join('|') %>"
        >
          <%= cat.categoryName %>
        </option>
        <% }) %>
      </select>
    </div>

    <!-- Subcategories -->
    <div id="subWrap" class="mb-3" style="display: none">
      <label class="form-label fw-bold">Subcategories</label>
      <div id="subChk"></div>
    </div>

    <!-- Featured -->
    <div class="form-check form-switch mb-4 ms-5">
      <input
        class="form-check-input"
        type="checkbox"
        name="isFeatured"
        id="feat"
      />
      <label class="form-check-label" for="feat">Featured Product</label>
    </div>

    <button type="submit" class="btn btn-gradient w-100">
      <i class="fas fa-plus me-2"></i>Add Product
    </button>
  </form>
</div>

<script>
  const d = document;
  /* ========== drag-drop ========= */
  const dz = document.getElementById("dropZone"),
    fi = document.getElementById("fileInp"),
    txt = document.getElementById("fileName");
  dz.addEventListener("click", () => fi.click());
  ["dragenter", "dragover"].forEach((ev) =>
    dz.addEventListener(ev, (e) => {
      e.preventDefault();
      dz.classList.add("dragover");
    })
  );
  ["dragleave", "drop"].forEach((ev) =>
    dz.addEventListener(ev, () => dz.classList.remove("dragover"))
  );
  dz.addEventListener("drop", (e) => {
    e.preventDefault();
    fi.files = e.dataTransfer.files;
    list();
  });
  fi.addEventListener("change", list);
  function list() {
    txt.textContent = [...fi.files].map((f) => f.name).join(", ");
  }

  /* ========== subcategory logic (LOOP approach) ========= */
  const subWrap = d.getElementById("subWrap"),
    subChk = d.getElementById("subChk"),
    catSel = d.getElementById("catSel");

  catSel.addEventListener("change", (e) => {
    const option = e.target.selectedOptions[0];
    const subs = (option.dataset.subs || "").split("|").filter(Boolean);

    subChk.innerHTML = "";
    if (subs.length === 0) {
      subWrap.style.display = "none";
      return;
    }
    // plain for-loop to create checkboxes
    for (let i = 0; i < subs.length; i++) {
      const s = subs[i];
      const uid = "sub_" + s.replace(/\\s+/g, "_");
      subChk.innerHTML += `
        <div class='form-check d-inline mx-2'>
          <input class='form-check-input' type='checkbox' name='subcategories' value='${s}' id='${uid}'>
          <label class='form-check-label fw-bold' for='${uid}'>${s}</label>
        </div>`;
    }
    subWrap.style.display = "block";
  });

  /* ========== bootstrap validation ========= */
  d.getElementById("productForm").addEventListener("submit", (e) => {
    if (!e.target.checkValidity()) {
      e.preventDefault();
      e.stopPropagation();
    }
    e.target.classList.add("was-validated");
  });
</script>
